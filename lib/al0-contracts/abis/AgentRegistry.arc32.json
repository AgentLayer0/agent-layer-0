    "contract": {
        "name": "AgentRegistry",
        "desc": "\n    On-chain registry for Agent Layer 0 swarms.\n\n    Box storage layout:\n      Key  : swarm_id (arc4.String)\n      Value: SwarmRecord { owner: Address, registered_at: UInt64 }\n    ",
        "methods": [
            {
                "name": "register_swarm",
                "args": [
                    {
                        "type": "string",
                        "name": "swarm_id",
                        "desc": "Unique identifier string (max 64 bytes)."
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "uint64",
                    "desc": "The current application ID (on-chain reference for the caller)."
                },
                "desc": "Register a new swarm. Caller becomes the owner."
            },
            {
                "name": "get_owner",
                "args": [
                    {
                        "type": "string",
                        "name": "swarm_id"
                    }
                ],
