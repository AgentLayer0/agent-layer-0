                        "name": "swarm_id"
                    }
                ],
                "readonly": true,
                "returns": {
                    "type": "bool"
                },
                "desc": "Check whether a swarm ID is registered."
            },
            {
                "name": "get_total_swarms",
                "args": [],
                "readonly": true,
