            "actions": {
                "create": [],
                "call": [
                    "NoOp"
                ]
            },
            "readonly": false,
            "desc": "Link this contract to the PollFactory.\nMust be called once by the contract creator after deployment, before any polls can be initialised.",
            "events": [],
            "recommendations": {}
        },
        {
            "name": "init_poll",
            "args": [
                {
                    "type": "uint64",
                    "name": "poll_id",
                    "desc": "The poll ID assigned by PollFactory.create_poll."
                }
            ],
            "returns": {
                "type": "void"
            },
            "actions": {
                "create": [],
                "call": [
                    "NoOp"
                ]
            },
            "readonly": false,
            "desc": "Register a poll so that votes can be cast against it.\nFetches authoritative `expires_at` and `option_count` from PollFactory via inner transaction \u2014 the caller cannot spoof these values.\nTypically called as a group transaction alongside PollFactory.create_poll, immediately after the poll is created.",
            "events": [],
            "recommendations": {}
        },
        {
            "name": "cast_vote",
            "args": [
                {
                    "type": "uint64",
                    "name": "poll_id"
                },
                {
                    "type": "uint64",
                    "name": "option_index"
                }
            ],
            "returns": {
                "type": "void"
            },
            "actions": {
                "create": [],
                "call": [
                    "NoOp"
                ]
            },
            "readonly": false,
            "desc": "Cast one vote on a poll.",
            "events": [],
            "recommendations": {}
        },
        {
            "name": "get_tally",
            "args": [
                {
                    "type": "uint64",
                    "name": "poll_id"
                }
            ],
