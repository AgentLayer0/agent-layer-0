                "type": "(uint64,uint64,uint64,uint64,uint64,uint64,uint64,uint64)",
                "struct": "TallyRecord"
            },
            "actions": {
                "create": [],
                "call": [
                    "NoOp"
                ]
            },
            "readonly": true,
            "desc": "Return the full tally record for a poll.",
            "events": [],
            "recommendations": {}
        },
        {
            "name": "has_voted",
            "args": [
                {
                    "type": "uint64",
