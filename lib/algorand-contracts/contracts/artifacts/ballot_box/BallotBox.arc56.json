            },
            "actions": {
                "create": [],
                "call": [
                    "NoOp"
                ]
            },
            "readonly": true,
            "desc": "Return the option index a voter chose (reverts if not voted).",
            "events": [],
            "recommendations": {}
        },
        {
            "name": "get_total_votes",
            "args": [],
