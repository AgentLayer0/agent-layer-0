            "returns": {
                "type": "bool"
            },
            "actions": {
                "create": [],
                "call": [
                    "NoOp"
                ]
            },
            "readonly": true,
            "desc": "Return true if the given voter has already cast a vote on this poll.",
            "events": [],
            "recommendations": {}
        },
        {
            "name": "get_vote",
            "args": [
                {
                    "type": "uint64",
                    "name": "poll_id"
                },
                {
                    "type": "address",
                    "name": "voter"
                }
            ],
