    "contract": {
        "name": "PollFactory",
        "desc": "\n    Factory for Agent Layer 0 governance polls.\n\n    Global state:\n      next_poll_id     : uint64 \u2014 monotonically increasing poll counter\n      registry_app_id  : uint64 \u2014 AgentRegistry application ID (set via bootstrap)\n\n    Box storage layout:\n      Key  : poll_id (arc4.UInt64)\n      Value: PollRecord struct\n    ",
        "methods": [
            {
                "name": "bootstrap",
                "args": [
                    {
                        "type": "uint64",
                        "name": "registry_app_id",
                        "desc": "Application ID of the deployed AgentRegistry contract."
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Link this contract to the AgentRegistry.\nMust be called once by the contract creator after deployment, before any polls can be created."
            },
            {
                "name": "create_poll",
                "args": [
                    {
                        "type": "string",
                        "name": "swarm_id"
                    },
                    {
                        "type": "string",
                        "name": "question"
                    },
                    {
                        "type": "string",
                        "name": "option_0"
                    },
                    {
                        "type": "string",
                        "name": "option_1"
                    },
                    {
                        "type": "string",
                        "name": "option_2"
                    },
                    {
                        "type": "string",
                        "name": "option_3"
                    },
                    {
                        "type": "string",
                        "name": "option_4"
                    },
                    {
                        "type": "string",
                        "name": "option_5"
                    },
                    {
                        "type": "string",
                        "name": "option_6"
                    },
                    {
                        "type": "string",
                        "name": "option_7"
                    },
                    {
                        "type": "uint64",
                        "name": "option_count"
                    },
                    {
                        "type": "uint64",
                        "name": "expires_at"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "uint64",
                    "desc": "Numeric poll ID (monotonically increasing)."
                },
                "desc": "Create a new governance poll.\nThe caller must be the registered owner of `swarm_id` in the linked AgentRegistry \u2014 verified via inner transaction."
            },
            {
                "name": "get_poll",
                "args": [
                    {
                        "type": "uint64",
                        "name": "poll_id"
                    }
                ],
                "readonly": true,
                "returns": {
                    "type": "(address,string,string,uint64,string,string,string,string,string,string,string,string,uint64,uint64)"
                },
                "desc": "Return the full poll record for a given poll ID."
            },
            {
                "name": "get_poll_meta",
                "args": [
                    {
                        "type": "uint64",
                        "name": "poll_id"
                    }
                ],
                "readonly": true,
                "returns": {
                    "type": "(uint64,uint64)"
                },
                "desc": "Return the lightweight poll metadata (expires_at, option_count).\nIntended for cross-contract calls from BallotBox.init_poll so it can verify poll provenance and read authoritative expiry/count without parsing the full PollRecord."
            },
            {
                "name": "is_active",
                "args": [
                    {
                        "type": "uint64",
                        "name": "poll_id"
                    }
                ],
                "readonly": true,
                "returns": {
                    "type": "bool"
                },
                "desc": "Return true if the poll exists and has not expired."
            },
            {
                "name": "get_next_poll_id",
                "args": [],
                "readonly": true,
                "returns": {
                    "type": "uint64"
                },
                "desc": "Return the next poll ID that will be assigned."
            },
            {
                "name": "get_registry_app_id",
                "args": [],
                "readonly": true,
                "returns": {
                    "type": "uint64"
                },
                "desc": "Return the linked AgentRegistry application ID."
            }
        ],
        "networks": {}
    },
    "bare_call_config": {
        "no_op": "CREATE"
    }
}